# Anthropic Claude (prioritaire si défini — ne jamais commiter la vraie clé)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Clé API OpenAI (ou clé factice "ollama" si vous utilisez Ollama en local)
OPENAI_API_KEY=sk-...
# Modèle de chat (compatible OpenAI API)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optionnel : base URL pour Ollama : http://localhost:11434/v1
# OPENAI_BASE_URL=

# CORS : origines autorisées pour le widget (séparées par des virgules). * = toutes
CORS_ORIGINS=*

# Chemins des données (relatifs à la racine du projet)
PAGES_JSONL=data/raw/pages_fr.jsonl
CHROMA_PATH=data/chroma

# Secours web (DuckDuckGo + extraction) si l'index est absent ou trop pauvre
# WEB_SEARCH_ENABLED=true
# RAG_MIN_CHARS=80
# WEB_MAX_DDG=8
# WEB_MAX_FETCH=3
# WEB_FETCH_TIMEOUT=12
