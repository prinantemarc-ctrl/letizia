# Anthropic Claude (prioritaire pour la génération)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (utilisé pour les embeddings + fallback LLM si pas d'Anthropic)
OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chroma Cloud (base vectorielle)
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=ck-...
CHROMA_TENANT=your-tenant-id
CHROMA_DATABASE=your-database-name
# CHROMA_COLLECTION=visit_corsica_fr

# CORS : origines autorisées pour le widget (* = toutes)
CORS_ORIGINS=*

# Données source (pour le script d'indexation)
PAGES_JSONL=data/raw/pages_fr.jsonl

# Recherche web DuckDuckGo
# WEB_SEARCH_ENABLED=true
# WEB_MAX_DDG=4
# WEB_MAX_FETCH=2
# WEB_FETCH_TIMEOUT=5
